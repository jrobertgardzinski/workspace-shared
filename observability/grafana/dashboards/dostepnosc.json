{
  "uid": "stack-availability",
  "title": "Stack — dostępność i zdrowie",
  "tags": ["stack", "availability"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Targety UP",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "unit": "short" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(up == 1)" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Targety DOWN",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(up == 0) or vector(0)" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Status per serwis (teraz)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 0 },
      "options": {
        "colorMode": "background", "graphMode": "none", "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up", "legendFormat": "{{job}}", "instant": true }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Dostępność w czasie (up per serwis)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10, "lineWidth": 2 },
          "min": 0, "max": 1, "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["min"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up", "legendFormat": "{{job}}" }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Ostrzeżenia i błędy — wszystkie serwisy (Loki)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 14 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=~\".+\"} |~ \"(?i)(warn|error|exception)\"" }
      ]
    }
  ]
}
