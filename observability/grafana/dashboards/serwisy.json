{
  "title": "Serwisy — HTTP, JVM i logi",
  "uid": "serwisy",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "svc",
        "label": "serwis",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_server_requests_seconds_count, job)",
        "refresh": 2,
        "current": { "text": "security", "value": "security" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Żądania / s — $svc",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"$svc\"}[2m]))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Czas odpowiedzi (śr. i max) — $svc",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_sum{job=\"$svc\"}[2m])) / sum(rate(http_server_requests_seconds_count{job=\"$svc\"}[2m]))",
          "legendFormat": "średni"
        },
        {
          "expr": "max(http_server_requests_seconds_max{job=\"$svc\"})",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Błędy 5xx / s — $svc",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"$svc\", status=~\"5..\"}[2m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "JVM: pamięć heap — $svc",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"$svc\", area=\"heap\"})",
          "legendFormat": "użyta"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{job=\"$svc\", area=\"heap\"} > 0)",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM: wątki — $svc",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"$svc\"}",
          "legendFormat": "żywe"
        },
        {
          "expr": "jvm_threads_peak_threads{job=\"$svc\"}",
          "legendFormat": "szczyt"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Logi — $svc (kliknięcie w linię: pola, cid, kontekst)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 16, "w": 8, "x": 16, "y": 8 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{service=\"$svc\"}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Ręczne eksportery: paddock (żądania/s per trasa)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (route) (rate(paddock_requests_total[2m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Ręczne eksportery: race-sim (żądania/s, aktywne jazdy)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum by (route) (rate(racesim_requests_total[2m]))",
          "legendFormat": "{{route}}"
        },
        {
          "expr": "racesim_drives_active",
          "legendFormat": "aktywne jazdy"
        }
      ]
    }
  ]
}
